    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/core": "^11.1.24",
    "@nestjs/testing": "^11.1.24",
    "@types/jest": "^30.0.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^24.10.1",
    "jest": "^30.0.0",
    "jest-util": "^30.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.24",
