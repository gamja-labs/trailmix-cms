{
    "name": "core-api",
    "version": "0.0.1",
    "description": "Minimal NestJS API built on @trailmix-cms/core (better-auth + security audits). Pairs with the core-web example frontend.",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "clean": "rm -rf dist",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "generate-spec": "GENERATE_SPEC=true nest start",
        "generate-client": "swagger-typescript-api generate --path ./docs/api-json.json --output ../core-web/src/client",
        "pretest:integration": "nest build",
        "test:integration": "jest --config ./test/integration/jest-integration.json --runInBand",
        "test:integration:docker": "docker compose -f test/integration/docker-compose.yml run --rm --build integration-tests; docker compose -f test/integration/docker-compose.yml down -v"
    },
    "dependencies": {
        "@fastify/static": "^9.0.0",
        "@nestjs/common": "^11.1.26",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.26",
        "@nestjs/platform-fastify": "^11.1.26",
        "@nestjs/swagger": "^11.4.4",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.0",
        "@thallesp/nestjs-better-auth": "^2.6.0",
        "@trailmix-cms/core": "workspace:*",
        "@trailmix-cms/db": "workspace:*",
        "@trailmix-cms/models": "workspace:*",
        "@trailmix-cms/utils": "workspace:*",
        "better-auth": "^1.6.10",
        "dotenv": "^16.4.7",
        "envalid": "^8.1.1",
        "fastify": "5.8.5",
        "mongodb": "^7.1.0",
        "nestjs-zod": "^5.4.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "reflect-metadata": "^0.2.2",
        "resend": "^6.0.0",
        "rxjs": "^7.8.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.1.0",
        "@nestjs/testing": "^11.1.26",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "jest": "^30.0.0",
        "jest-util": "^30.4.1",
        "source-map-support": "^0.5.21",
        "swagger-typescript-api": "^13.2.16",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "6.0.3"
    }
}
