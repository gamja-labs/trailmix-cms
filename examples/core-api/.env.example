PORT=4001
SERVICE_HOST=http://localhost:4001

# Origin of the core-web frontend — allowed for credentialed CORS and trusted by better-auth.
WEB_ORIGIN=http://localhost:5175

# MongoDB — a single connection is shared between better-auth and @trailmix-cms/db
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DATABASE_NAME=core-api

# better-auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:4001

# Email (Resend) — when RESEND_API_KEY is unset the app falls back to a LogEmailSender (no real
# mail is sent, the flows just log). Set both to deliver verification / reset / invite emails.
RESEND_API_KEY=
EMAIL_FROM=Trailmix <onboarding@resend.dev>
